Options -Indexes
Options +FollowSymLinks

RewriteEngine On

# Force HTTPS (uncomment on live server)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 1. Redirect /index.php → / (canonical homepage)
RewriteCond %{THE_REQUEST} \s/+index\.php[?\ ] [NC]
RewriteRule ^ / [R=301,L]

# 2. Redirect /page.php → /page (301 for SEO — skip admin/)
RewriteCond %{THE_REQUEST} \s/+(?!admin/)([a-zA-Z0-9_-]+)\.php[?\ ] [NC]
RewriteRule ^ /%1 [R=301,NE,QSA,L]

# 3. Redirect /articles → /blog (301)
RewriteRule ^articles$ /blog [R=301,L]

# Explicit routes — must be before generic rule
RewriteRule ^blog$                              blog.php                      [END,QSA]
RewriteRule ^packages$                          packages.php                  [END,QSA]
RewriteRule ^bachelor$                          bachelor.php                  [END,QSA]
RewriteRule ^attractions$                       attractions.php               [END,QSA]
RewriteRule ^hotels$                            hotels.php                    [END,QSA]
RewriteRule ^package/([a-zA-Z0-9_-]+)$         package-detail.php?slug=$1    [END,QSA]
RewriteRule ^article/([a-zA-Z0-9_-]+)$         article.php?id=$1             [END,QSA]

# 4. Internally route clean URLs → .php files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/admin/
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [END,QSA]

# Default charset and compression
AddDefaultCharset UTF-8

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css             "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml        "access plus 1 week"
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
